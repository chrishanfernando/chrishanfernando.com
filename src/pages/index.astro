---
import Base from '../layouts/Base.astro';
import profile from '../data/profile.json';
import experience from '../data/experience.json';
import projects from '../data/projects.json';

const githubIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`;
const linkedinIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4V8h4v1.5A6 6 0 0 1 16 8z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`;
const mailIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>`;
const folderIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`;
---

<Base>
  <nav>
    <div class="nav-inner">
      <a href="#top" class="nav-logo"><span class="accent">chrishan</span>fernando<span class="accent">.com</span></a>
      <ul class="nav-links">
        <li><a href="#about"><span class="idx">01.</span>about</a></li>
        <li><a href="#experience"><span class="idx">02.</span>experience</a></li>
        <li><a href="#projects"><span class="idx">03.</span>projects</a></li>
        <li><a href="#contact"><span class="idx">04.</span>contact</a></li>
      </ul>
    </div>
  </nav>

  <main id="top" class="container">
    <header class="hero">
      <p class="hero-pre">// hi, my name is</p>
      <h1>{profile.name}<span class="cursor" aria-hidden="true"></span></h1>
      <h2>{profile.title} <span class="accent">·</span> {profile.tagline}</h2>
      <p class="summary">{profile.summary}</p>
      <p class="hero-meta">📍 {profile.location}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#projects">view projects</a>
        <a class="btn btn-ghost" href="/resume.pdf" download>download resume</a>
      </div>
    </header>

    <section id="about" class="reveal">
      <div class="section-heading">
        <span class="num">01.</span>
        <h2>About</h2>
        <span class="rule"></span>
      </div>
      <div class="about-grid">
        <div class="about-text">
          {profile.about.map((para) => <p>{para}</p>)}
          <div class="edu-card">
            <div class="degree">{profile.education.degree}</div>
            <div class="inst">{profile.education.institution} · {profile.education.period}</div>
            <div class="notes">{profile.education.notes}</div>
          </div>
        </div>
        <div class="about-skills">
          {profile.skills.map((block) => (
            <div class="skills-block">
              <h3>{block.group}</h3>
              <div class="chips">
                {block.items.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="experience" class="reveal">
      <div class="section-heading">
        <span class="num">02.</span>
        <h2>Experience</h2>
        <span class="rule"></span>
      </div>
      <div class="timeline">
        {experience.map((job) => (
          <article class="job">
            <div class="job-header">
              <h3>{job.role} <span class="company">@ {job.company}</span></h3>
              <span class="period">{job.period}</span>
            </div>
            <div class="job-tags chips">
              {job.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
            <ul>
              {job.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="projects" class="reveal">
      <div class="section-heading">
        <span class="num">03.</span>
        <h2>Things I've Built</h2>
        <span class="rule"></span>
      </div>
      <div class="projects-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-top">
              <span class="folder" set:html={folderIcon} />
              <div class="project-links">
                {project.github && (
                  <a href={project.github} target="_blank" rel="noopener" aria-label={`${project.name} on GitHub`} set:html={githubIcon} />
                )}
              </div>
            </div>
            <h3><a href={project.github} target="_blank" rel="noopener">{project.name}</a></h3>
            <p>{project.description}</p>
            <div class="chips">
              {project.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="contact" class="contact reveal">
      <div class="section-heading">
        <span class="num">04.</span>
        <h2>Get In Touch</h2>
        <span class="rule"></span>
      </div>
      <p class="lede">
        Whether it's clinical AI, systems engineering in regulated environments,
        or something you're tinkering with — my inbox is open.
      </p>
      <a class="contact-email" href={`mailto:${profile.email}`}>{profile.email}</a>
      <div class="contact-socials">
        <a href={profile.github} target="_blank" rel="noopener" aria-label="GitHub" set:html={githubIcon} />
        <a href={profile.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" set:html={linkedinIcon} />
        <a href={`mailto:${profile.email}`} aria-label="Email" set:html={mailIcon} />
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> ·
      deployed on <a href="https://workers.cloudflare.com" target="_blank" rel="noopener">Cloudflare</a> ·
      updated by <a href="https://claude.com/claude-code" target="_blank" rel="noopener">Claude Code</a>
    </div>
  </footer>
</Base>
